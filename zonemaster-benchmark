# return the list of module present in a zonemaster results
sub list_modules {
        my (@entries) = @_;
        return uniq sort map { $_->module } @entries;
}

# return the list of testcases present inside results
# delete Unspecified
sub list_testcases{
        my (@entries) = @_;
        my @results = uniq sort map { $_->testcase } @entries;
        @results = grep { $_ ne "Unspecified" } @results;       # HACK
        return @results
}

sub time_testcase {
        my ($entries, $filter_testcase) = @_;
        my @entries = @$entries;
        #printf "entries %d\n", scalar(@entries);
        #printf "filter = %s\n", $filter_testcase;
        #$filter_testcase //= '';  # Sécurité
        #my @filtered = map { $_->testcase} @entries;
        my @filtered = grep { $_->testcase eq $filter_testcase } @entries;
        #printf scalar(@filtered);
        my ($start) = grep { $_->tag eq "TEST_CASE_START" } @filtered;
        my ($end) = grep { $_->tag eq "TEST_CASE_END" } @filtered;
        #printf "%f\n",$end->timestamp;
        #printf "%f\n",$start->timestamp;
        return $end->timestamp - $start->timestamp;
}

sub timing {
    my (@entries) = @_;
    my @list_testcase = list_testcases(@entries);
    my %times; 
    foreach my $testcase (@list_testcase) {
        #printf("%s: %f\n",$testcase, time_testcase(\@entries, $testcase));
        $times{$testcase} = time_testcase(\@entries, $testcase);
    }
    return %times;
}

sub print_summary {
	my (@datas) = @_;
	print @datas;

    my %sum;
    my %count;
    
    for my $row (@datas) {
        for my $key (keys %{$row}) {
            my $val = $row->{$key};
    
            # Skip non-numeric values (hostname, domain, date, etc.)
            next unless defined $val;
            next unless $val =~ /^-?\d+(?:\.\d+)?$/;
    
            $sum{$key}   += $val;
            $count{$key} += 1;
        }
    }
    
    
    my %mean;
    for my $key (keys %sum) {
        $mean{$key} = $sum{$key} / $count{$key};
    }
    
    # Print means
    for my $key (sort keys %mean) {
        printf "%s => %.12f\n", $key, $mean{$key};
    }

}

