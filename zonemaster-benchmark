# Usage:
#   zonemaster-benchmark example.com
#   zonemaster-benchmark --batch domains.txt
#   zonemaster-benchmark example.com
#   zonemaster-benchmark --batch domains.txt
#
# But NOT both a domain and --batch at the same time.

my $batch_file;
my $ref_file;
my $use_cache = 0;
my $cache_dir = "/tmp/";  # DEFAULT CACHE DIRECTORY
my $profile;
my $opt_nbruns = 1;
my $opt_output;

#TODO: add nbrun. if nbrun =0 means juste cache
GetOptions(
    'batch=s' => \$batch_file,
    'cache'   => \$use_cache,
    'cache_dir=s' => \$cache_dir,
    'profile=s' => \$profile,
    'nbruns=i' => \$opt_nbruns,
    'out=s' => \$opt_output
) or die "Usage: $0 [--ref FILE] (domain | --batch FILE)\n";

# Check mutual exclusivity between domain and --batch
my $domain_arg = $ARGV[0];

if (defined $batch_file && defined $domain_arg) {
    die "Error: use either a single domain OR --batch FILE, not both.\n";
}

if (!defined $batch_file && !defined $domain_arg) {
    die "Error: you must specify either a domain or --batch FILE.\n";
}

# Collect domains
my @domains;

if (defined $batch_file) {
    open my $bfh, '<', $batch_file
      or die "Cannot open batch file '$batch_file': $!\n";
    while (my $line = <$bfh>) {
        chomp $line;
        next if $line =~ /^\s*$/;
        push @domains, $line;
    }
    close $bfh;
} else {
    push @domains, $domain_arg;
}

# Validate cache_dir if cache is enabled
if ($use_cache) {
    unless (-d $cache_dir && -w $cache_dir) {
        die "Cache directory '$cache_dir' must exist and be writable\n";
    }
}

# Validate profile file
if (defined $profile) {
    unless (-e $profile && -r $profile){
        die "Profile file '$profile' must exist and be readable\n";
    }
}

my @collected_datas;
my $domain_count=0;

for my $d (@domains) {

    $domain_count++;

    
    my $cache_file = "$cache_dir/$d.cache";
    if ( $use_cache ) {
        unless (-e $cache_file && -r $cache_file && -s $cache_file) {
            #if cache file doesnt exist, create it
            print("$cache_file file does not exist, creating it...\n");
            Zonemaster::Engine->reset();
            Zonemaster::Engine->test_zone($d);
            Zonemaster::Engine->save_cache($cache_file);
        }
    }

    
    for my $run (1..$opt_nbruns){
        Zonemaster::Engine->reset();

        # Loading cache 
        if( $use_cache ){
            #print("load cache file $cache_file\n");
            Zonemaster::Engine->preload_cache($cache_file);
        }
    
        # Loading profile
        if (defined $profile) {
            my $json    = read_file( $profile );
            my $foo     = Zonemaster::Engine::Profile->from_json( $json );
            my $profile = Zonemaster::Engine::Profile->default;
            $profile->merge( $foo );
            Zonemaster::Engine::Profile->effective->merge( $profile ); 
        }
    
        printf("%i/%i: ",$domain_count,scalar(@domains)); 
        print("benchmarking $d (run $run/$opt_nbruns) : "); 
        STDOUT->flush();     
        #printf("hostname: %s\n",hostname());
        #printf("date: %s\n",[gettimeofday]);
        	#printf("date: %s\n",localtime->strftime('%m/%d/%Y %H:%M'));
        my $start = [gettimeofday];
        my @results = Zonemaster::Engine->test_zone($d);
        my $elapsed = tv_interval($start);
        printf("%f \r",$elapsed);
    
        # without reseting, loading cache after the first one while not work 
        Zonemaster::Engine->reset();
    
        my %times = timing(@results);
        $times{'domain'} = $d;
        $times{'time'} = $elapsed,
        $times{'hostname'} = hostname(),
        $times{'date'} = localtime->strftime('%m/%d/%Y %H:%M'),
        $times{'VersionEngine'} = Zonemaster::Engine->VERSION;
#        $times{'meta'}={'domain', $d,
#                        'time', $elapsed,
#                        'hostname',hostname(),
#                        'date', localtime->strftime('%m/%d/%Y %H:%M'),
#                        'VersionEngine', Zonemaster::Engine->VERSION};
        #open my $fh, ">", "data_out.json";
        #print $fh encode_json(\%times);
        #close $fh;
        push @collected_datas, {%times}
        #Zonemaster::Engine->save_cache("cache");
    }
    print("\n");
}

#TODO: stock other metadata
# cmd line used 
if ($opt_output){
	open my $fh, ">", $opt_output;
	print $fh encode_json(\@collected_datas);
	close $fh;
} else {
	# otherwise print summary on terminal
	print_summary(@collected_datas);
	print_summary2(@collected_datas);
}

