#!/usr/bin/env perl
use strict;
use warnings;
use Getopt::Long;
use Time::Piece;
use Zonemaster::Engine;
use Sys::Hostname;
use List::Util qw(uniq pairmap);
use Time::HiRes qw(gettimeofday tv_interval);
